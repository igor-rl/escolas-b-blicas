generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Turma {
  id          String   @id @default(uuid())
  escola      String
  descricao   String?
  dataInicio  String?
  dataTermino String?
  createdAt   DateTime @default(now())
}
