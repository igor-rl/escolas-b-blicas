{
  "name": "escolas-biblicas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:electron-main": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "dev:electron": "npm run prisma:copy-assets && npm run build:electron-main && concurrently -k -s first \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "prisma:prepare": "node src/main/database/prepare-prisma.mjs",
    "prisma:copy-assets": "node src/main/database/copy-prisma-engine.mjs",
    "build:electron:prepare": "npm run prisma:prepare && npm run build:electron-main && npm run prisma:copy-assets",
    "build:electron": "npm run build && npm run build:electron:prepare && electron-builder",
    "build:electron-win": "npm run build && npm run build:electron:prepare && electron-builder --win nsis --x64",
    "build:electron-win-portable": "npm run build && npm run build:electron:prepare && electron-builder --win portable --x64",
    "preview": "vite preview",
    "release": "git tag v$(node -p \"require('./package.json').version\") && git push origin --tags"
  },
  "build": {
    "appId": "com.escolas-biblicas.app",
    "productName": "EB",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-macOS-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-windows-installer-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-windows-portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.14.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prisma": "^6.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
